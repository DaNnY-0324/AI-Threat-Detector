# =============================================================================
# AI-Enhanced Cybersecurity Threat Detector — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic (Claude API) — used in Phase 5 onward
# console.anthropic.com → API Keys → Create key
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# VirusTotal — IOC enrichment, Phase 4 onward (500 req/day free tier)
# virustotal.com → Profile → API key
# -----------------------------------------------------------------------------
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# -----------------------------------------------------------------------------
# AbuseIPDB — IP reputation scoring, Phase 4 onward (1,000 req/day free tier)
# abuseipdb.com → Account → API → Create key
# -----------------------------------------------------------------------------
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# -----------------------------------------------------------------------------
# Microsoft Azure — Phase 3 onward
# portal.azure.com → Azure Active Directory → Overview
# -----------------------------------------------------------------------------
AZURE_TENANT_ID=your_azure_tenant_id_here
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id_here
AZURE_RESOURCE_GROUP=ai-threat-detector-rg

# Azure AD App Registration (for programmatic Sentinel/Defender API access)
# Azure portal → App registrations → New registration
AZURE_CLIENT_ID=your_app_registration_client_id_here
AZURE_CLIENT_SECRET=your_app_registration_client_secret_here

# -----------------------------------------------------------------------------
# Microsoft Sentinel / Azure Log Analytics — Phase 3 onward
# portal.azure.com → Log Analytics workspaces → your workspace → Agents
# -----------------------------------------------------------------------------
SENTINEL_WORKSPACE_ID=your_log_analytics_workspace_id_here
SENTINEL_SHARED_KEY=your_log_analytics_primary_key_here

# -----------------------------------------------------------------------------
# Microsoft Defender for Endpoint — Phase 3 onward
# MDE API uses the Azure AD App Registration credentials above (AZURE_CLIENT_*)
# security.microsoft.com → Settings → Endpoints → APIs
# -----------------------------------------------------------------------------
MDE_TENANT_ID=${AZURE_TENANT_ID}

# -----------------------------------------------------------------------------
# Splunk — Phase 3 onward
# Splunk Web → Settings → Data Inputs → HTTP Event Collector → New Token
# -----------------------------------------------------------------------------
SPLUNK_HEC_URL=http://splunk:8088
SPLUNK_HEC_TOKEN=your_splunk_hec_token_here
SPLUNK_INDEX=threat_detector

# -----------------------------------------------------------------------------
# XSOAR Community Edition — Phase 4 onward
# XSOAR Web UI → Settings → Integrations → API Keys
# -----------------------------------------------------------------------------
XSOAR_URL=https://xsoar:443
XSOAR_API_KEY=your_xsoar_api_key_here

# -----------------------------------------------------------------------------
# Detection pipeline (internal — set after Phase 2)
# -----------------------------------------------------------------------------
MODEL_API_URL=http://api:8000
ANOMALY_THRESHOLD_LOW=0.3
ANOMALY_THRESHOLD_MEDIUM=0.5
ANOMALY_THRESHOLD_HIGH=0.7
ANOMALY_THRESHOLD_CRITICAL=0.9

# PCAP rolling capture settings
PCAP_MAX_FILE_SIZE_MB=50
PCAP_OUTPUT_DIR=/captures

# -----------------------------------------------------------------------------
# Frontend dashboard (Phase 5)
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost:8000
REACT_APP_SPLUNK_URL=http://localhost:8000
